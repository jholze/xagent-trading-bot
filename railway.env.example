# Copy these variables into Railway → Service → Variables
# Do NOT commit real secrets.

# --- Required ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MongoDB — Option A: Railway Mongo (empfohlen, gleiches Projekt)
# Im Bot-Service Variable referenzieren: ${{Mongo.MONGO_URL}}
# (Service-Name kann abweichen — im Railway-Dashboard unter Mongo → Variables nachsehen)
# MONGO_URL wird automatisch vom Mongo-Service gesetzt

# Option B: explizit setzen (Atlas oder Railway Public URL)
# MONGODB_URI=mongodb://...

MONGODB_DB=xagent_test

# Set by Railway automatically when you enable a public domain:
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# Or set explicitly:
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# --- Demo mode (matches local start_demo_with_ngrok.sh) ---
# Set by scripts/railway_start.sh automatically:
# DEMO_MODE=1
# DEMO_LEDGER_BACKEND=mongo
# RAILWAY_DEPLOY=1

# --- Optional API keys (same as local .env) ---
GATE_API_KEY=
GATE_SECRET=
OPENAI_API_KEY=
CMC_API_KEY=
X_BEARER_TOKEN=

# --- Optional tuning ---
# WEBHOOK_DROP_PENDING=1
# HOST=0.0.0.0
# PORT=5000